# syntax=docker/dockerfile:1.4
FROM python:3.11

WORKDIR /app

ARG RASP
ARG https_proxy
ARG http_proxy
ENV RASP ${RASP}
ENV https_proxy ${https_proxy}
ENV http_proxy ${http_proxy}
ENV no_proxy="127.0.0.1,localhost,intel.com"

# Note: proxy is passed in via build ARGs only when the host has it set.
# No hardcoded proxy values are written here so this builds with or without proxy.

# Install OS dependencies
RUN apt-get update -y
RUN apt-get install -y gcc libpq-dev

# Install app dependencies
COPY requirements.txt /app
RUN pip3 install -r requirements.txt

# Export some env vars flask needs
ENV FLASK_APP=src.app:create_app
ENV FLASK_ENV=development

# Run migrations & start flask app
ENTRYPOINT ["sh", "-c", "flask db upgrade && python3 run.py"]
